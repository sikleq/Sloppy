{
  "_version": 1,
  "_doc": "Declarative source of truth for hero innate stat bonuses. Used by builders/heroes_stats.py (level-1 seeding) and src/scripts.js (per-level recompute on the heroes-stats table). Stage 1 of innate centralization — do not edit without verifying against KV files in data/stats/<patch>/heroes/.",
  "_constants": {
    "HPREG_PER_STR": 0.1,
    "MANAREG_PER_INT": 0.05,
    "AS_PER_AGI": 1.0,
    "ARMOR_PER_AGI": 0.16667,
    "MR_PER_INT": 0.1,
    "OGRE_MANA_PER_STR": 6.0,
    "OGRE_MANAREG_PER_STR": 0.02
  },
  "_formula_types": {
    "attr_factor": "bonus = attrs[source] * factor",
    "base_plus_level": "bonus = base + per_level * level",
    "flat_per_level": "bonus = per_level * level",
    "self_attr_pct_per_level": "bonus = attrs[target] * (base_pct + per_level_pct * level)  -- self-referential, target==source",
    "attr_pct_per_level": "bonus = attrs[source] * (base_pct + per_level_pct * level)",
    "hp_pct": "bonus = current_hp * factor / 100  (current_hp includes str scaling)",
    "mana_pool_pct_per_level": "bonus = current_mp * (base_pct + per_level_pct * level)  (current_mp includes int scaling)",
    "ms_multiplier": "multiplier = 1 + (base_pct + per_level_pct * level) / 100  (applied multiplicatively to move speed)",
    "armor_factor": "bonus = (armor_base + agi * ARMOR_PER_AGI) * factor  (armor_base = ArmorPhysical KV field)",
    "secondary_attr_factor": "bonus = derived_stat_from_attr * factor  (hpr: STR*HPREG_PER_STR; mpr: INT*MANAREG_PER_INT; aspd: AGI*AS_PER_AGI; armor: AGI*ARMOR_PER_AGI; mr: INT*MR_PER_INT)",
    "dmg_universal_bonus_pct": "universal_dmg_mult *= (1 + factor)  (applied inside primary-damage calc, only for Universal heroes)",
    "attr_substitution": "replaces the attribute used to derive target stat (Ogre: STR derives MP and MPR instead of INT)",
    "mana_shield_ehp": "ehp_bonus = current_mp * absorb_pct * damage_per_mana  (damage absorbed by spending mana; dpm scales with level)"
  },
