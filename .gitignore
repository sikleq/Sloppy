__pycache__/
*.pyc
*.pyo

# Промежуточные артефакты — воспроизводятся через generate_patch_code.py
_generated_p_*.py
_insert_patches.py

# Scratch-выгрузка shop-файлов из VPK (scripts/extract_shops.py, разведка формата)
data/_vpk_shops/

# Список URL иконок — генерируется build_patch.py для check_icons.py
_ability_icons.txt

# Raw npc_units.txt blobs cached by scripts/fetch_npc_history.py (keyed by
# d2vpkr commit SHA). Large; the parsed data/stats/<patch>/npc_units.json is
# what we commit and the build consumes.
.cache/

# IDE / editor local config
.claude/
.vscode/
.idea/

# Generated by build_patch.py — produced fresh by CI and deployed to Pages,
# never committed to keep .git slim.
patches/*.html
calendar.html
creeps.html
materials.html
neutral_creeps.html
mana_items.html
unit_abilities.html
neutral_abilities.html
heroes_dyn.html
items_dyn.html
terrain.html
index.html
_dynamics.json
data/site_meta.json

# Raw Valve API dumps — fetched ad-hoc via scripts/fetch_*.py for inspection
# / one-off generation; not load-bearing for the build.
data/*_datafeed.json

# Abandoned logo experiment — kept locally, not committed
icons/Pixel Logo.gif

# Reference source images for hand-adapted icons (stock/watermarked) — kept
# locally so icons can be re-derived, never committed/deployed.
icons/ref/

# Telethon auth session for scripts/fetch_signatures.py — never commit
*.session
*.session-journal

# NOTE: data/signatures.json IS committed now — we deploy the real member
# display-name list (display names, owner/links/empties excluded per
# scripts/fetch_signatures.py). It's just data, so the wall has real names on
# CI. (If absent, build_patch.py still falls back to random placeholders.)

# Local one-command refresh helper — contains the Telegram api_hash, never commit
run_signatures.ps1
